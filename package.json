{
  "name": "lab-back",
  "version": "0.1.0",
  "private": true,
  "description": "Backend del sistema de laboratorio bioquimico (NestJS + Drizzle + Supabase)",
  "license": "UNLICENSED",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "build": "rimraf dist && nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:setup": "ts-node -r tsconfig-paths/register src/db/setup.ts",
    "db:seed": "ts-node -r tsconfig-paths/register src/db/seed.ts",
    "db:reset": "ts-node -r tsconfig-paths/register src/db/reset.ts",
    "db:inspect": "ts-node -r tsconfig-paths/register src/db/inspect.ts",
    "db:import-nbu": "ts-node -r tsconfig-paths/register src/db/import-nbu.ts",
    "verify-nbu": "python practicas-migration/verify.py",
    "smoke": "ts-node -r tsconfig-paths/register src/dev/smoke.ts"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.5.0",
    "@react-pdf/renderer": "4.1.6",
    "@supabase/supabase-js": "2.47.10",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.4",
    "decimal.js": "10.4.3",
    "dotenv": "^16.4.7",
    "drizzle-orm": "0.45.2",
    "googleapis": "^173.0.0",
    "helmet": "^8.0.0",
    "multer": "^1.4.5-lts.1",
    "postgres": "3.4.5",
    "react": "19.0.0",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.12.4",
    "rxjs": "^7.8.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/compression": "^1.7.5",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.0",
    "@types/multer": "^2.1.0",
    "@types/node": "22.10.5",
    "@types/react": "19.0.2",
    "@types/supertest": "^6.0.0",
    "drizzle-kit": "0.31.10",
    "jest": "^29.7.0",
    "rimraf": "6.0.1",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "5.7.2"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts", "tsx", "jsx"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)sx?$": "ts-jest"
    },
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/$1"
    }
  }
}
