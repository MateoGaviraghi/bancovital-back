{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "assets": [
      { "include": "pdf/fonts/*.ttf", "outDir": "dist" },
      { "include": "pdf/*.jpeg", "outDir": "dist" },
      { "include": "pdf/*.png", "outDir": "dist" }
    ],
    "watchAssets": true
  }
}
