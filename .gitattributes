# Normalize line endings to LF on checkout
* text=auto eol=lf

# Binary files — no EOL conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.ttf binary
*.otf binary
*.woff binary
*.woff2 binary
*.eot binary
*.pdf binary
*.zip binary
*.gz binary
*.tar binary
*.tgz binary
